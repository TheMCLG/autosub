# AutoSub Environment Variables Example
# Rename this file to `.env` if using Docker Compose's env_file directive, or use it as a reference for your environment exports.

# --- REQUIRED ---
# Plex server URL including http(s):// and port
PLEX_URL=http://YOUR_PLEX_IP:32400

# Your Plex authentication token
PLEX_TOKEN=YOUR_PLEX_TOKEN_HERE

# Port for the Flask server to listen for webhooks
WEBHOOK_PORT=8765

# --- AI SETTINGS ---
# Whisper model size. Options: tiny, base, small, medium, large, large-v2, large-v3, large-v3-turbo.
# Recommended: large-v3 for accuracy
WHISPER_MODEL=large-v3

# Compute device for Whisper. Options: cpu or cuda for Nvidia GPU's
WHISPER_DEVICE=cpu

# Precision type for model computation. Recommended: int8 for cpu or float16 for cuda
WHISPER_COMPUTETYPE=int8

# Number of CPU threads to use (only applicable for cpu)
WHISPER_CPUTHREADS=4

# Whisper task. Options: transcribe (original language) or translate (forces English)
WHISPER_TASK=translate

# --- FILTER SETTINGS ---
# Comma-separated list containing audio languages for which you do NOT want to generate subtitles (e.g. 'en, de, fr')
SKIP_LANGUAGES=en

# Comma-separated list containing subtitle languages. Will NOT generate a subtitle if the file has an existing subtitle matching this.
SKIP_SUB_LANGUAGES=en

# --- ADVANCED ---
# Set to True to enable debug logging
DEBUG_LOGGING=False

# Controls max concurrent background transcription tasks. Highly recommended to leave at 1 to prevent VRAM/RAM exhaustion.
WEBHOOK_EXECUTOR_MAX_WORKERS=1